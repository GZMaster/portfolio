# Optional: higher GitHub API rate limits for `npm run build` / CI (not bundled to client)
# GITHUB_TOKEN=

# Canonical URL for OG / Twitter meta (Vite injects into index.html at build time)
# VITE_SITE_URL=https://gzmaster.dev

# Optional: enables mailto in Contact section
# VITE_CONTACT_EMAIL=you@example.com
