# Optional: higher GitHub API rate limits for `npm run build` / CI (not bundled to client)
# GITHUB_TOKEN=

# Canonical URL for OG / Twitter / JSON-LD / sitemap (build-time)
# VITE_SITE_URL=https://gzmaster.dev

# Optional: used in JSON-LD sameAs (default GZMaster)
# VITE_GITHUB_USERNAME=GZMaster

# Optional: twitter:site & twitter:creator (with or without @)
# VITE_TWITTER_HANDLE=GZMaster

# Optional: Search Console / Bing Webmaster meta tags (build-time)
# VITE_GOOGLE_SITE_VERIFICATION=
# VITE_BING_SITE_VERIFICATION=

# Optional: enables mailto in Contact section
# VITE_CONTACT_EMAIL=you@example.com
